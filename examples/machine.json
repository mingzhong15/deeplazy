{
  "machine": {
    "batch_type": "Slurm",
    "context_type": "LocalContext",
    "local_root": "./",
    "remote_root": "./"
  },
  "resources": {
    "number_node": 1,
    "cpu_per_node": 64,
    "queue_name": "normal",
    "group_size": 50,
    "custom_flags": [
      "#SBATCH --exclusive",
      "#SBATCH --exclude=node8,node20,node22,node26",
      "#SBATCH --time=48:00:00"
    ],
    "source_list": [
      "/public/home/tangzc/intel/oneapi/setvars.sh"
    ],
    "envs": {
      "LD_LIBRARY_PATH": "/public/home/tangzc/env/hdf5-1.12.1/lib:${LD_LIBRARY_PATH}"
    },
    "prepend_script": ["ulimit -l unlimited"]
  },
  "openmx": {
    "executable": "/public/home/mind/software/openmx/3.9.9_devel/openmx",
    "data_path": "/public/home/mind/software/openmx/DFT_DATA19",
    "mpi_cmd": "mpirun -np {cpus}",
    "module_path": "../co-opt-calc",
    "cpus_per_task": 64
  },
  "deeph": {
    "executable": "/public/home/mind/software/uv-env/deeph-1.2.6/bin/deepx",
    "device": "cpu",
    "float_type": "fp32",
    "batch_size": 1,
    "jit_num": 4,
    "log_level": "info",
    "random_seed": 137
  },
  "job_name_prefix": "lz"
  ,
  "backward_files": ["hamiltonians_step*.h5", "openmx.out", "*.dat"]
}
